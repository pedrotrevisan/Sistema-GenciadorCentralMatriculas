# Configuração do Banco de Dados
# Para PostgreSQL (recomendado):
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/db_central_matriculas

# Para SQLite (desenvolvimento), deixe DATABASE_URL comentado ou remova a linha

# JWT - Troque em produção!
JWT_SECRET_KEY=sua-chave-secreta-troque-em-producao

# CORS - URLs permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000
